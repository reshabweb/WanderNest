<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans">
  <%- include('../partials/header') %>
  
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Manage Your Properties</h1>
      <p class="text-gray-600">Here are all the homes you're hosting</p>
      
      
      
    </div>

    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% registeredHomes.forEach(home => { %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300">
          
          <div class="relative h-64">
            <img 
              src="<%= home.photo %>" 
              alt="<%= home.houseName %>" 
              class="w-full h-full object-cover"
            >
            
            <span class="absolute top-4 left-4 px-3 py-1 bg-green-500 text-white text-sm font-medium rounded-full">
              Active
            </span>
          </div>

          
          <div class="p-6">
            
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-bold text-gray-800"><%= home.houseName %></h3>
              <div class="flex items-center bg-yellow-50 px-2 py-1 rounded-lg">
                <i class="fas fa-star text-yellow-400 mr-1"></i>
                <span class="font-semibold text-gray-700"><%= home.rating %></span>
              </div>
            </div>

            
            <p class="flex items-center text-gray-600 mb-4">
              <i class="fas fa-map-marker-alt text-red-500 mr-2"></i>
              <%= home.location %>
            </p>

            
            <div class="text-lg font-bold text-red-500 mb-6">
              ₹<%= home.price %> <span class="text-sm font-normal text-gray-600">/ night</span>
            </div>

            
            <div class="flex gap-4">
              <a href="/host/edit-home/<%= home._id %>?editing=true" 
                 class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2 
                        bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-100 
                        transition-colors duration-300 font-medium">
                <i class="fas fa-edit"></i>
                Edit
              </a>
              
              <form action="/host/delete-home/<%= home._id %>" method="POST" class="flex-1">
                <button type="submit"
                        class="w-full inline-flex items-center justify-center gap-2 px-4 py-2 
                               bg-red-50 text-red-600 rounded-lg hover:bg-red-100 
                               transition-colors duration-300 font-medium">
                  <i class="fas fa-trash-alt"></i>
                  Delete
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    
    <% if (registeredHomes.length === 0) { %>
      <div class="text-center py-16">
        <div class="text-gray-400 mb-4">
          <i class="fas fa-home text-6xl"></i>
        </div>
        <h3 class="text-xl font-semibold text-gray-700 mb-2">No homes listed yet</h3>
        <p class="text-gray-600 mb-6">Start by adding your first property</p>
        <a href="/host/add-home" 
           class="inline-flex items-center gap-2 px-6 py-3 bg-red-500 text-white rounded-lg
                  hover:bg-red-600 transition-colors duration-300 font-medium">
          <i class="fas fa-plus"></i>
          Add Your First Home
        </a>
      </div>
    <% } %>
  </main>
</body>
</html>
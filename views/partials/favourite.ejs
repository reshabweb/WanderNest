<form action="/favourites" method="POST">
  <!-- <button type="submit" class="bg-green-300 p-2 hover:bg-green-500 ">Add to Favourite</button> -->

  <button onclick="toggleFavourite('<%= home._id %>')" class="w-full bg-red-500 text-white py-3 rounded-lg font-semibold flex items-center justify-center gap-2 hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors duration-300"> <i class="<%= home.isFavourite ? 'fas' : 'far' %> fa-heart"></i>
    <%= home.isFavourite ? 'Remove from Favourites' : 'Add to Favourites' %> 
  </button>

  <input type="hidden" name="id" value="<%= home._id %>">
  
</form>
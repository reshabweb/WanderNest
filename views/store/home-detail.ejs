<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans">
    <%- include('../partials/header') %>
    
    
    <div class="container mx-auto px-4 py-4 max-w-6xl">
        <nav class="flex text-gray-500 text-sm">
            <a href="/" class="hover:text-red-500">Home</a>
            <span class="mx-2">›</span>
            <span class="text-gray-900"><%= home.houseName %></span>
        </nav>
    </div>

    <main class="container mx-auto px-4 mb-16 max-w-6xl">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
            
            <div class="relative h-[500px]">
                <img 
                    src="<%= home.photo %>" 
                    alt="<%= home.houseName %>" 
                    class="w-full h-full object-cover"
                >
            </div>

            
            <div class="p-8">
                <div class="flex justify-between items-start mb-6">
                    <h1 class="text-4xl font-bold text-gray-900"><%= home.houseName %></h1>
                    <div class="flex items-center bg-yellow-50 px-3 py-1.5 rounded-lg">
                        <i class="fas fa-star text-yellow-400 mr-2"></i>
                        <span class="font-semibold text-gray-700"><%= home.rating %></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    
                    <div class="lg:col-span-2 space-y-8">
                        
                        <div class="flex items-start space-x-3">
                            <i class="fas fa-map-marker-alt text-red-500 mt-1"></i>
                            <div>
                                <h3 class="font-semibold text-gray-900 mb-1">Location</h3>
                                <p class="text-gray-600"><%= home.location %></p>
                            </div>
                        </div>

                        
                        <div class="flex items-start space-x-3">
                            <i class="fas fa-home text-red-500 mt-1"></i>
                            <div>
                                <h3 class="font-semibold text-gray-900 mb-1">About this place</h3>
                                <p class="text-gray-600 leading-relaxed"><%= home.description %></p>
                            </div>
                        </div>
                    </div>

                    
                    <div class="lg:col-span-1">
                        <div class="bg-white rounded-xl border shadow-sm p-6">
                            <div class="mb-6">
                                <span class="text-2xl font-bold text-gray-900">₹<%= home.price %></span>
                                <span class="text-gray-600">/night</span>
                            </div>
                            
                            <%- include('../partials/favourite' )%>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
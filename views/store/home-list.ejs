<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans">
  <%- include('../partials/header') %>

  <main class="container mx-auto px-4 py-8 max-w-7xl">
    <h1 class="text-4xl font-bold text-center text-gray-800 mb-8">
      Discover Amazing Places to Stay
      <span class="block text-lg font-normal text-gray-600 mt-2">
        Find the perfect home for your next adventure
      </span>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% registeredHomes.forEach(home => { %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">

          <div class="relative h-64">
            <img 
              src="<%= home.photo %>" 
              alt="<%= home.houseName %>" 
              class="w-full h-full object-cover"
            >
            
          </div>

          <div class="p-6">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-xl font-bold text-gray-800">
                <%= home.houseName %>
              </h3>
              <div class="flex items-center bg-yellow-50 px-2 py-1 rounded-lg">
                <i class="fas fa-star text-yellow-400 mr-1"></i>
                <span class="font-semibold text-gray-700"><%= home.rating %></span>
              </div>
            </div>

            <p class="flex items-center text-gray-600 mb-4">
              <i class="fas fa-map-marker-alt text-red-500 mr-2"></i>
              <%= home.location %>
            </p>

            
            <div class="flex justify-between items-center mt-4">
              <span class="text-xl font-bold text-red-500">
                ₹<%= home.price %> <span class="text-sm font-normal text-gray-600">/ night</span>
              </span>
              <a href="/homes/<%= home._id %>" 
                 class="inline-flex items-center px-4 py-2 bg-red-500 text-white rounded-lg 
                        hover:bg-red-600 transition-colors duration-300">
                View Details
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </main>
</body>
</html>
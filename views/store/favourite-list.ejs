<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans">
  <%- include('../partials/header') %>
  
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Your Favorite Homes</h1>
      <p class="text-gray-600">Places you've saved for later</p>
    </div>

    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% favouriteHomes.forEach(home => { %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
          
          <div class="relative h-64">
            <img 
              src="<%= home.photo %>" 
              alt="<%= home.houseName %>" 
              class="w-full h-full object-cover"
            >
          </div>

          
          <div class="p-6 space-y-4">
            
            <div class="flex justify-between items-start">
              <h3 class="text-xl font-bold text-gray-800"><%= home.houseName %></h3>
              <div class="flex items-center bg-yellow-50 px-2 py-1 rounded-lg">
                <i class="fas fa-star text-yellow-400 mr-1"></i>
                <span class="font-semibold text-gray-700"><%= home.rating %></span>
              </div>
            </div>

            
            <p class="flex items-center text-gray-600">
              <i class="fas fa-map-marker-alt text-red-500 mr-2"></i>
              <%= home.location %>
            </p>

            
            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <div class="text-lg font-bold text-red-500">
                ₹<%= home.price %> <span class="text-sm font-normal text-gray-600">/ night</span>
              </div>
              
              <form action="/favourites/delete/<%= home._id %>" method="POST">
                <button 
                  type="submit"
                  class="flex items-center gap-2 px-4 py-2 bg-red-50 text-red-500 rounded-lg
                         hover:bg-red-100 transition-colors duration-300 font-medium"
                >
                  <i class="fas fa-heart-broken"></i>
                  Remove
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    
    <% if (favouriteHomes.length === 0) { %>
      <div class="text-center py-16">
        <div class="text-gray-400 mb-4">
          <i class="far fa-heart text-6xl"></i>
        </div>
        <h3 class="text-xl font-semibold text-gray-700 mb-2">No favorites yet</h3>
        <p class="text-gray-600 mb-6">Start saving some places you like</p>
        <a href="/homes" class="inline-flex items-center gap-2 px-6 py-3 bg-red-500 text-white rounded-lg
                                hover:bg-red-600 transition-colors duration-300 font-medium">
          <i class="fas fa-search"></i>
          Explore Homes
        </a>
      </div>
    <% } %>
  </main>
</body>
</html>

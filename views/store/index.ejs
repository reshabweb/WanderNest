<%- include('../partials/head') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 font-sans">
  <%- include('../partials/header') %>

  
  <div class="bg-gradient-to-r from-red-500 to-red-600 text-white py-16">
    <div class="container mx-auto px-4 max-w-6xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Find Your Perfect Stay
      </h1>
      <p class="text-xl text-red-100 mb-8">
        Discover unique homes and experiences
      </p>
    </div>
  </div>

  <main class="container mx-auto px-4 py-12 max-w-7xl">
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">
        Featured Places to Stay
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% registeredHomes.forEach(home => { %>
          <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
            
            <div class="relative h-64">
              <img 
                src="<%= home.photo %>" 
                alt="<%= home.houseName %>" 
                class="w-full h-full object-cover"
              >
              
            </div>

            
            <div class="p-6">
              
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-xl font-bold text-gray-800">
                  <%= home.houseName %>
                </h3>
                <div class="flex items-center bg-yellow-50 px-2 py-1 rounded-lg">
                  <i class="fas fa-star text-yellow-400 mr-1"></i>
                  <span class="font-semibold text-gray-700"><%= home.rating %></span>
                </div>
              </div>

              
              <p class="flex items-center text-gray-600 mb-4">
                <i class="fas fa-map-marker-alt text-red-500 mr-2"></i>
                <%= home.location %>
              </p>

              
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="text-lg font-bold text-red-500">
                  ₹<%= home.price %> <span class="text-sm font-normal text-gray-600">/ night</span>
                </div>
                
                <a  
                   class="inline-flex items-center gap-2 px-4 py-2 bg-red-500 text-white rounded-lg
                          hover:bg-red-600 transition-colors duration-300">
                  Book Now
                  <i class="fas fa-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</body>
</html>